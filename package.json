{
  "name": "heroes-reforged-ai-realms",
  "private": true,
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "src/contracts"
  ],
  "scripts": {
    "generate:task-registry": "node scripts/generate-task-registry.mjs",
    "generate:task-system-report": "node scripts/generate-task-system-report.mjs",
    "generate:wiki": "node scripts/generate-architecture-wiki.mjs",
    "generate:contracts": "node scripts/generate-contracts-from-schemas.mjs",
    "validate:links": "node scripts/check-markdown-links.mjs",
    "validate:contracts": "node scripts/check-repo-contracts.mjs",
    "validate:contracts-ts": "node scripts/generate-contracts-from-schemas.mjs",
    "validate:cross-refs": "node scripts/check-cross-references.mjs",
    "validate:commands": "node scripts/check-command-coverage.mjs",
    "validate:task-commands": "node scripts/check-task-command-literals.mjs",
    "validate:tasks": "node scripts/tasks.mjs lint",
    "validate:arch": "node scripts/check-module-graph.mjs",
    "validate:ui-components": "node scripts/validate-screen-component-coverage.mjs",
    "validate:animation-budgets": "node scripts/validate-animation-budgets.mjs",
    "validate:enums": "node scripts/check-enum-snapshot.mjs",
    "validate:balance": "node scripts/validate-balance.mjs",
    "validate:error-codes": "node scripts/check-pack-error-codes.mjs",
    "validate:provenance": "node scripts/check-decision-provenance.mjs",
    "validate:runtime-requirements": "node scripts/check-runtime-requirements.mjs",
    "validate:deferred": "node scripts/check-deferred-coverage.mjs",
    "validate:diagram-task-parity": "node scripts/check-diagram-task-parity.mjs",
    "validate:error-ux": "node scripts/check-error-ux-coverage.mjs",
    "validate:build-attestation": "node scripts/check-build-attestation.mjs",
    "validate:no-stochastic-preview": "node scripts/check-no-stochastic-preview.mjs",
    "validate:unused-scripts": "node scripts/check-unused-scripts.mjs",
    "build:asset-index": "node scripts/build-asset-index.mjs",
    "generate:enum-snapshot": "node scripts/snapshot-enums.mjs",
    "validate": "npm run generate:task-registry && npm run validate:links && npm run validate:contracts && npm run validate:contracts-ts && npm run validate:cross-refs && npm run validate:commands && npm run validate:tasks && npm run validate:arch && npm run validate:ui-components && npm run validate:animation-budgets && npm run validate:enums && npm run validate:balance && npm run validate:error-codes && npm run validate:provenance && npm run validate:runtime-requirements && npm run validate:deferred && npm run validate:diagram-task-parity && npm run validate:error-ux && npm run validate:build-attestation && npm run validate:no-stochastic-preview && npm run validate:unused-scripts && npm run build:asset-index -- --check",
    "test": "node --test scripts/__tests__/*.test.mjs",
    "test:ui-smoke": "vitest --browser run -- src/ui/**/*.smoke.test.ts",
    "test:golden": "vitest run src/engine/__tests__/golden.test.ts",
    "test:replays": "vitest run src/engine/__tests__/replays.test.ts",
    "test:coverage": "vitest run --coverage",
    "bench:engine": "vitest bench src/engine/__tests__/throughput.bench.ts",
    "golden:bless": "node scripts/golden-bless.mjs",
    "tasks:next": "node scripts/tasks.mjs next",
    "tasks:next:mvp": "node scripts/tasks.mjs next --phase=mvp",
    "tasks:next:p2": "node scripts/tasks.mjs next --phase=phase-2",
    "tasks:next:p3": "node scripts/tasks.mjs next --phase=phase-3",
    "tasks:next:phase-2": "node scripts/tasks.mjs next --phase=phase-2",
    "tasks:next:phase-3": "node scripts/tasks.mjs next --phase=phase-3",
    "tasks:next:hot": "node scripts/tasks.mjs next --hot",
    "tasks:next:hot:mvp": "node scripts/tasks.mjs next --hot --phase=mvp",
    "tasks:next:json": "node scripts/tasks.mjs next --json",
    "tasks:status": "node scripts/tasks.mjs status",
    "tasks:show": "node scripts/tasks.mjs show",
    "tasks:start": "node scripts/tasks.mjs start",
    "tasks:done": "node scripts/tasks.mjs done",
    "tasks:blocked": "node scripts/tasks.mjs blocked",
    "tasks:lint": "node scripts/tasks.mjs lint",
    "all": "npm run validate && npm run generate:wiki && npm run generate:task-system-report"
  }
}
