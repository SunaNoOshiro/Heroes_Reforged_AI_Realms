# Heroes Reforged — root npm config.
#
# Source plan:
#   docs/implementation-plans/30-dependencies-and-build-pipeline-plan.md
#   — Critical Fix "Postinstall scripts run unsandboxed in CI" and
#     "No version pinning policy / no engines / no packageManager".
#
# - save-exact: when a developer runs `npm install <pkg>`, pin the
#   exact version (no caret/tilde drift across PRs).
# - ignore-scripts: never run postinstall / preinstall / install hooks
#   from any dep; explicit allowlisted natives are rebuilt via
#   `scripts/install-trusted.sh`. See dependency-policy.md § 8.
# - engine-strict: a contributor on the wrong Node major fails
#   `npm ci` instead of producing inscrutable runtime errors.
# - fund: silence the donation banner.
# - audit: run audit explicitly via `npm run audit:npm` so it lives
#   in its own CI step, not on every `npm ci`.
save-exact=true
ignore-scripts=true
engine-strict=true
fund=false
audit=false
