{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/schema.json",
  "minTokens": 60,
  "minLines": 8,
  "threshold": 100,
  "reporters": ["json"],
  "output": "reports/jscpd",
  "absolute": false,
  "gitignore": true,
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/reports/**",
    "**/.stryker-tmp/**",
    "**/__tests__/**",
    "**/__fixtures__/**",
    "**/fixtures/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.smoke.test.ts",
    "**/*.bench.ts",
    "src/contracts/**",
    "src/content-schema/migrations/example-*",
    "tests/**",
    "tasks/**",
    "docs/**",
    "research/**",
    "resources/**",
    "scripts/**"
  ],
  "format": ["typescript", "tsx"]
}
