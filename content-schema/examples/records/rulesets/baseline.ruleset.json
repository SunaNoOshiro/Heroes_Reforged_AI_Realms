{
  "$schema": "heroes-reforged/ruleset.schema.json",
  "schemaVersion": 1,
  "id": "shared:ruleset:baseline",
  "version": "0.1.0",
  "constants": {
    "atkBonusPerPointNum": 1,
    "atkBonusPerPointDen": 20,
    "defReductionPerPointNum": 1,
    "defReductionPerPointDen": 20,
    "atkBonusCap": 60,
    "defReductionCap": 60,
    "fixedPointBasis": 1000,
    "moraleExtraTurnProbNum": 1,
    "moraleExtraTurnProbDen": 24,
    "moralePenaltyMissProbNum": 1,
    "moralePenaltyMissProbDen": 24,
    "moraleMax": 3,
    "luckDoubleProbNum": 1,
    "luckDoubleProbDen": 24,
    "luckMax": 3,
    "autoResolveAttackerAdvantageNum": 105,
    "autoResolveAttackerAdvantageDen": 100,
    "defendDamageReductionPermille": 250,
    "heroExperiencePerLevel": 500,
    "magicManaPerKnowledge": 10,
    "magicMysticismRegenBase": 1,
    "magicMysticismRegenPerLevel": 1,
    "magicSpellPowerDamageMultiplier": 1,
    "siegeWallSegmentHp": 1500,
    "siegeWallBreachThresholdNum": 1,
    "siegeWallBreachThresholdDen": 2,
    "siegeGateHp": 1000,
    "siegeMoatDamageNum": 70,
    "siegeMoatDamageDen": 1,
    "siegeMoatPassable": true,
    "siegeTowerDamage": 20,
    "siegeTowerShotsPerRound": 1,
    "siegeDrawbridgeRaisedDefaultRounds": 0,
    "townTierVillageGoldPerDay": 500,
    "townTierTownGoldPerDay": 1000,
    "townTierCityHallGoldPerDay": 2000,
    "townTierCapitolGoldPerDay": 4000,
    "combatBattlefieldMaxStacks": 14,
    "heroArmyMaxStacks": 7
  },
  "magic": {
    "manaPerKnowledge": 10,
    "mysticismRegenBase": 1,
    "mysticismRegenPerLevel": 1,
    "spellPowerDamageMultiplier": 1
  },
  "siege": {
    "wallSegmentHp": 1500,
    "wallBreachThresholdNum": 1,
    "wallBreachThresholdDen": 2,
    "gateHp": 1000,
    "moatDamageNum": 70,
    "moatDamageDen": 1,
    "moatPassable": true,
    "towerDamage": 20,
    "towerShotsPerRound": 1,
    "drawbridgeRaisedDefaultRounds": 0
  },
  "townTier": {
    "village":  { "goldPerDay": 500 },
    "town":     { "goldPerDay": 1000 },
    "cityHall": { "goldPerDay": 2000 },
    "capitol":  { "goldPerDay": 4000 }
  },
  "combat": {
    "battlefieldMaxStacks": 14
  },
  "heroLevelup": {
    "classWeights": {
      "knight":      { "pre10": [35, 45, 10, 10], "post10": [25, 30, 20, 25] },
      "cleric":      { "pre10": [10, 10, 30, 50], "post10": [10, 10, 40, 40] },
      "ranger":      { "pre10": [30, 40, 15, 15], "post10": [25, 25, 25, 25] },
      "druid":       { "pre10": [15, 15, 40, 30], "post10": [10, 10, 40, 40] },
      "necromancer": { "pre10": [15, 15, 35, 35], "post10": [10, 10, 40, 40] }
    }
  },
  "formulas": {
    "attackBonus": {
      "op": "mul",
      "args": [
        {
          "op": "clamp",
          "args": [
            {
              "op": "sub",
              "args": [
                { "op": "var", "path": "attacker.attack" },
                { "op": "var", "path": "defender.defense" }
              ]
            },
            { "op": "const", "value": 0 },
            { "op": "var", "path": "ruleset.atkBonusCap" }
          ]
        },
        {
          "op": "ratio",
          "args": [
            { "op": "var", "path": "ruleset.atkBonusPerPointNum" },
            { "op": "var", "path": "ruleset.atkBonusPerPointDen" }
          ]
        }
      ]
    },
    "defenseMitigation": {
      "op": "mul",
      "args": [
        {
          "op": "clamp",
          "args": [
            {
              "op": "sub",
              "args": [
                { "op": "var", "path": "defender.defense" },
                { "op": "var", "path": "attacker.attack" }
              ]
            },
            { "op": "const", "value": 0 },
            { "op": "var", "path": "ruleset.defReductionCap" }
          ]
        },
        {
          "op": "ratio",
          "args": [
            { "op": "var", "path": "ruleset.defReductionPerPointNum" },
            { "op": "var", "path": "ruleset.defReductionPerPointDen" }
          ]
        }
      ]
    },
    "defendDamageReduction": {
      "op": "var",
      "path": "ruleset.defendDamageReductionPermille"
    }
  },
  "ui": {
    "timing": {
      "tooltipHoldDelayMs": 350,
      "tooltipFadeInMs": 120,
      "tooltipFadeOutMs": 80,
      "doubleClickWindowMs": 400,
      "longPressMs": 600,
      "dragThresholdPx": 8,
      "inputDebounceMs": 50,
      "endTurnAnimationMaxMs": 4000
    },
    "editor": {
      "maxHistory": 200
    }
  }
}
