{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heroes-reforged/skill.schema.json",
  "title": "Skill",
  "description": "Hero secondary skill. Each level grants one or more effects from the closed effect registry.",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "levels"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "id":            { "type": "string", "minLength": 1 },
    "name":          { "type": "string", "minLength": 1 },
    "description":   { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "levels": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["mastery", "effects"],
        "properties": {
          "mastery": { "type": "string", "enum": ["basic", "advanced", "expert"] },
          "effects": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "heroes-reforged/effect.schema.json" }
          }
        },
        "additionalProperties": false
      }
    },
    "presentation": {
      "type": "object",
      "properties": {
        "iconId": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
