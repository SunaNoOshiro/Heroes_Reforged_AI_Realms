{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heroes-reforged/spell.schema.json",
  "title": "Spell",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "school",
    "level",
    "scope",
    "manaCost",
    "targeting",
    "masteryTiers"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "id":            { "type": "string", "minLength": 1 },
    "name":          { "type": "string", "minLength": 1 },
    "school":        { "type": "string", "enum": ["fire", "water", "earth", "air", "light", "dark", "arcane", "nature"] },
    "level":         { "type": "integer", "minimum": 1, "maximum": 5 },
    "scope":         { "type": "string", "enum": ["combat", "adventure", "both"] },
    "manaCost":      { "type": "integer", "minimum": 0 },
    "targeting":     { "$ref": "heroes-reforged/targeting.schema.json" },
    "masteryTiers": {
      "type": "object",
      "required": ["basic", "advanced", "expert"],
      "properties": {
        "basic":    { "$ref": "#/$defs/masteryTier" },
        "advanced": { "$ref": "#/$defs/masteryTier" },
        "expert":   { "$ref": "#/$defs/masteryTier" }
      },
      "additionalProperties": false
    },
    "immunities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "presentation": {
      "type": "object",
      "properties": {
        "iconId":         { "type": "string" },
        "animationSetId": { "type": "string" },
        "vfxSetId":       { "type": "string" },
        "soundSetId":     { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "masteryTier": {
      "type": "object",
      "required": ["effects"],
      "properties": {
        "effects": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "heroes-reforged/effect.schema.json" }
        }
      },
      "additionalProperties": false
    }
  }
}
