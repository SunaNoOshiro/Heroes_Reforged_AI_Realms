{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heroes-reforged/world.schema.json",
  "title": "World",
  "description": "A named world container: biomes, procedural generator presets, and ambient presentation. No free-form fields.",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "biomeIds",
    "generatorPresetIds",
    "presentation"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "biomeIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "generatorPresetIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "presentation": {
      "type": "object",
      "required": ["ambientMusicId", "loadingArtId"],
      "properties": {
        "ambientMusicId": { "type": "string", "minLength": 1 },
        "loadingArtId": { "type": "string", "minLength": 1 },
        "paletteId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
