{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heroes-reforged/ruleset.schema.json",
  "title": "Ruleset",
  "description": "Balance constants and formulas. Formulas are structured fixed-point ASTs (see formula.schema.json), not strings, so deterministic replay is preserved across engines and no eval() is ever required.",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "version",
    "constants",
    "formulas"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "id":            { "type": "string", "minLength": 1 },
    "version":       { "type": "string", "minLength": 1 },
    "constants": {
      "type": "object",
      "description": "Named integer (or integer-tuple) balance constants. Fractional ratios live as paired numerator/denominator integers (e.g. atkBonusPerPointNum=1, atkBonusPerPointDen=20).",
      "additionalProperties": {
        "oneOf": [
          { "type": "integer" },
          { "type": "boolean" },
          { "type": "string" },
          {
            "type": "array",
            "items": { "type": "integer" }
          }
        ]
      }
    },
    "formulas": {
      "type": "object",
      "additionalProperties": { "$ref": "heroes-reforged/formula.schema.json" }
    },
    "magic": {
      "type": "object",
      "description": "Mana pool and spell damage scaling constants. Pinned by docs/architecture/spells-and-mage-guild.md §6a/6b.",
      "properties": {
        "manaPerKnowledge":            { "type": "integer", "minimum": 0 },
        "mysticismRegenBase":          { "type": "integer", "minimum": 0 },
        "mysticismRegenPerLevel":      { "type": "integer", "minimum": 0 },
        "spellPowerDamageMultiplier":  { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "siege": {
      "type": "object",
      "description": "Siege-state-machine constants. Values are placeholders pending balance pass; shape is pinned by tasks/phase-2/01-spells-artifacts/13-siege-state-machine.md.",
      "properties": {
        "wallSegmentHp":               { "type": "integer", "minimum": 0 },
        "wallBreachThresholdNum":      { "type": "integer", "minimum": 0 },
        "wallBreachThresholdDen":      { "type": "integer", "minimum": 1 },
        "gateHp":                      { "type": "integer", "minimum": 0 },
        "moatDamageNum":               { "type": "integer", "minimum": 0 },
        "moatDamageDen":               { "type": "integer", "minimum": 1 },
        "moatPassable":                { "type": "boolean" },
        "towerDamage":                 { "type": "integer", "minimum": 0 },
        "towerShotsPerRound":          { "type": "integer", "minimum": 0 },
        "drawbridgeRaisedDefaultRounds": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "townTier": {
      "type": "object",
      "description": "Per-tier town income (Village → Town → City Hall → Capitol). Owned by mvp.04-faction-emberwild.02-emberwild-town-building-tree.",
      "properties": {
        "village":  { "$ref": "#/$defs/townTierEntry" },
        "town":     { "$ref": "#/$defs/townTierEntry" },
        "cityHall": { "$ref": "#/$defs/townTierEntry" },
        "capitol":  { "$ref": "#/$defs/townTierEntry" }
      },
      "additionalProperties": false
    },
    "combat": {
      "type": "object",
      "description": "Tactical combat-grid limits. battlefieldMaxStacks caps how many stacks may exist on the battlefield (initial + summoned + raised). See docs/architecture/in-combat-stack-rules.md.",
      "properties": {
        "battlefieldMaxStacks": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "heroLevelup": {
      "type": "object",
      "description": "Per-class primary-stat growth weights. Each tuple is [attack, defense, power, knowledge] integers summing to 100. Owned by phase-2.01-spells-artifacts.00-hero-leveling.",
      "properties": {
        "classWeights": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["pre10", "post10"],
            "properties": {
              "pre10":  { "$ref": "#/$defs/levelupWeightTuple" },
              "post10": { "$ref": "#/$defs/levelupWeightTuple" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "ui": {
      "type": "object",
      "description": "Optional UI-only thresholds and editor limits. Content-driven so QA can tune timing without code edits. UI numbers do not enter deterministic gameplay state.",
      "properties": {
        "timing": {
          "type": "object",
          "description": "Numeric thresholds for tooltip lifecycle, gesture detection, input debounce, and animation gates. Pinned by ui-gestures.md, ui-input-arbitration.md, and ui-state-contract.md.",
          "properties": {
            "tooltipHoldDelayMs":    { "type": "integer", "minimum": 0 },
            "tooltipFadeInMs":       { "type": "integer", "minimum": 0 },
            "tooltipFadeOutMs":      { "type": "integer", "minimum": 0 },
            "doubleClickWindowMs":   { "type": "integer", "minimum": 0 },
            "longPressMs":           { "type": "integer", "minimum": 0 },
            "dragThresholdPx":       { "type": "integer", "minimum": 0 },
            "inputDebounceMs":       { "type": "integer", "minimum": 0 },
            "endTurnAnimationMaxMs": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "editor": {
          "type": "object",
          "description": "Map-editor history limits and other editor-shell ceilings. See ui-state-contract.md § Undo / Redo.",
          "properties": {
            "maxHistory": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "townTierEntry": {
      "type": "object",
      "required": ["goldPerDay"],
      "properties": {
        "goldPerDay": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "levelupWeightTuple": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "type": "integer", "minimum": 0, "maximum": 100 }
    }
  }
}
