{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heroes-reforged/match-handshake.schema.json",
  "title": "MatchHandshake",
  "description": "Three-phase commit-reveal handshake message for the M5 multiplayer module. Discriminated by `phase`. Authoritative doctrine: docs/architecture/match-handshake.md. Owning task: tasks/phase-3/01-multiplayer/10-match-handshake-protocol.md.",
  "oneOf": [
    { "$ref": "#/$defs/Commit" },
    { "$ref": "#/$defs/Reveal" },
    { "$ref": "#/$defs/Accept" },
    { "$ref": "#/$defs/Abort" }
  ],
  "$defs": {
    "Commit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "peerId", "commit"],
      "properties": {
        "phase": { "const": "COMMIT" },
        "peerId": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$",
          "description": "xxh64 hex of (nonce || contentHash || engineHash || packManifestDigest || bundleSha256 || signaturePolicy). All inputs canonical-JSON encoded before concatenation, in the order listed."
        }
      }
    },
    "Reveal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "peerId",
        "nonce",
        "contentHash",
        "engineHash",
        "packManifestDigest",
        "bundleSha256",
        "signaturePolicy"
      ],
      "properties": {
        "phase": { "const": "REVEAL" },
        "peerId": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "nonce": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "32 raw CSPRNG bytes, lower-case hex. Generated by globalThis.crypto.getRandomValues; never PCG32."
        },
        "contentHash": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$",
          "description": "xxh64 hex over the entire active pack tree per pack-contract.md."
        },
        "engineHash": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$",
          "description": "xxh64 hex of the engine's own determinism-relevant identity per determinism.md."
        },
        "packManifestDigest": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$",
          "description": "xxh64 hex over canonical-JSON of manifest.json. Re-sent at end-of-turn alongside the per-turn state hash so a mid-match pack swap triggers MID_MATCH_PACK_SWAP abort."
        },
        "bundleSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "Lower-case hex SHA-256 of the engine bundle. Required to be in the canonical allow-list per build-attestation.md when signaturePolicy = required-ranked."
        },
        "signaturePolicy": {
          "type": "string",
          "enum": ["optional", "required-friendly", "required-ranked"]
        },
        "packSignature": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scheme", "keyId", "sig"],
          "properties": {
            "scheme": { "const": "ed25519" },
            "keyId": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" },
            "sig": { "type": "string", "pattern": "^[0-9a-f]{128}$" }
          }
        }
      }
    },
    "Accept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "peerId", "matchId"],
      "properties": {
        "phase": { "const": "ACCEPT" },
        "peerId": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "matchId": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
          "description": "Echo of the agreed matchId derived as xxh64('matchId-v1' || nonceA || nonceB) rendered in UUID v4 textual form."
        }
      }
    },
    "Abort": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "peerId", "reason"],
      "properties": {
        "phase": { "const": "ABORT" },
        "peerId": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "reason": {
          "type": "string",
          "enum": [
            "COMMIT_MISMATCH",
            "CONTENT_HASH_MISMATCH",
            "ENGINE_HASH_MISMATCH",
            "PACK_DIGEST_MISMATCH",
            "BUILD_ATTESTATION_MISMATCH",
            "PACK_SIGNATURE_REQUIRED",
            "PACK_SIGNATURE_INVALID",
            "HANDSHAKE_TIMEOUT",
            "PROTOCOL_ERROR"
          ]
        }
      }
    }
  }
}
