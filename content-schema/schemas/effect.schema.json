{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heroes-reforged/effect.schema.json",
  "title": "Effect",
  "description": "Closed, discriminated effect kinds consumed by spells, abilities, and artifacts. Runtime effect handlers are resolved via the `kind` discriminator. Adding a new effect kind requires a new subschema and a new handler registration — never a free-form string. Conditions use the closed condition AST, not free-form DSL strings.",
  "type": "object",
  "required": ["kind"],
  "oneOf": [
    { "$ref": "#/$defs/damage" },
    { "$ref": "#/$defs/heal" },
    { "$ref": "#/$defs/status" },
    { "$ref": "#/$defs/modifyStat" },
    { "$ref": "#/$defs/modifyPrimaryStat" },
    { "$ref": "#/$defs/summon" },
    { "$ref": "#/$defs/dispel" },
    { "$ref": "#/$defs/resourceBonus" },
    { "$ref": "#/$defs/grantSpell" },
    { "$ref": "#/$defs/grantAbility" },
    { "$ref": "#/$defs/unlockUnit" },
    { "$ref": "#/$defs/unlockBuilding" },
    { "$ref": "#/$defs/spawnArmy" },
    { "$ref": "#/$defs/setFlag" },
    { "$ref": "#/$defs/awardResources" },
    { "$ref": "#/$defs/growthModifier" }
  ],
  "$defs": {
    "damage": {
      "type": "object",
      "required": ["kind", "amount"],
      "properties": {
        "kind":       { "const": "damage" },
        "damageType": { "type": "string", "enum": ["physical", "fire", "cold", "lightning", "earth", "air", "holy", "shadow", "pure"] },
        "amount":     { "$ref": "heroes-reforged/formula.schema.json" },
        "target":     { "$ref": "heroes-reforged/target-scope.schema.json" },
        "condition":  { "$ref": "heroes-reforged/condition.schema.json" }
      },
      "additionalProperties": false
    },
    "heal": {
      "type": "object",
      "required": ["kind", "amount"],
      "properties": {
        "kind":      { "const": "heal" },
        "amount":    { "$ref": "heroes-reforged/formula.schema.json" },
        "target":    { "$ref": "heroes-reforged/target-scope.schema.json" },
        "condition": { "$ref": "heroes-reforged/condition.schema.json" }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "object",
      "required": ["kind", "status"],
      "description": "Named status effect. `duration` is interpreted in `durationUnit`s. Default unit is `rounds` for combat-scope spells/abilities and `days` for adventure-scope. Default stacking is `highest_magnitude_refresh_duration`. See docs/architecture/status-effects.md.",
      "properties": {
        "kind":         { "const": "status" },
        "status":       { "$ref": "heroes-reforged/status-id.schema.json" },
        "duration":     { "type": "integer", "minimum": 0 },
        "durationUnit": { "type": "string", "enum": ["rounds", "turns", "days"] },
        "stacking":     { "type": "string", "enum": ["stack", "refresh", "highest_magnitude_refresh_duration", "ignore"] },
        "magnitude":    { "type": "integer" },
        "target":       { "$ref": "heroes-reforged/target-scope.schema.json" },
        "condition":    { "$ref": "heroes-reforged/condition.schema.json" }
      },
      "additionalProperties": false
    },
    "modifyStat": {
      "type": "object",
      "required": ["kind", "stat", "value"],
      "properties": {
        "kind":      { "const": "modify_stat" },
        "stat":      { "$ref": "heroes-reforged/stat-id.schema.json" },
        "value":     { "type": "integer" },
        "target":    { "$ref": "heroes-reforged/target-scope.schema.json" },
        "duration":  { "type": "integer", "minimum": 0 },
        "condition": { "$ref": "heroes-reforged/condition.schema.json" }
      },
      "additionalProperties": false
    },
    "modifyPrimaryStat": {
      "type": "object",
      "required": ["kind", "stat", "value"],
      "properties": {
        "kind":  { "const": "modify_primary_stat" },
        "stat":  { "type": "string", "enum": ["attack", "defense", "power", "knowledge"] },
        "value": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "summon": {
      "type": "object",
      "required": ["kind", "unitId", "count"],
      "properties": {
        "kind":   { "const": "summon" },
        "unitId": { "type": "string", "minLength": 1 },
        "count":  { "$ref": "heroes-reforged/formula.schema.json" }
      },
      "additionalProperties": false
    },
    "dispel": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind":   { "const": "dispel" },
        "scope":  { "type": "string", "enum": ["positive", "negative", "all"] },
        "target": { "$ref": "heroes-reforged/target-scope.schema.json" }
      },
      "additionalProperties": false
    },
    "resourceBonus": {
      "type": "object",
      "required": ["kind", "resource", "amount"],
      "properties": {
        "kind":     { "const": "resource_bonus" },
        "resource": { "$ref": "heroes-reforged/resource-id.schema.json" },
        "amount":   { "type": "integer" },
        "cadence":  { "type": "string", "enum": ["once", "daily", "weekly"] }
      },
      "additionalProperties": false
    },
    "grantSpell": {
      "type": "object",
      "required": ["kind", "spellId"],
      "properties": {
        "kind":    { "const": "grant_spell" },
        "spellId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "grantAbility": {
      "type": "object",
      "required": ["kind", "abilityId"],
      "properties": {
        "kind":      { "const": "grant_ability" },
        "abilityId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "unlockUnit": {
      "type": "object",
      "required": ["kind", "unitId"],
      "properties": {
        "kind":   { "const": "unlock_unit" },
        "unitId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "unlockBuilding": {
      "type": "object",
      "required": ["kind", "buildingId"],
      "properties": {
        "kind":       { "const": "unlock_building" },
        "buildingId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "spawnArmy": {
      "type": "object",
      "description": "Spawn a fixed army at a hex. Used by map triggers.",
      "required": ["kind", "stacks", "q", "r"],
      "properties": {
        "kind": { "const": "spawn_army" },
        "q":    { "type": "integer" },
        "r":    { "type": "integer" },
        "playerId": { "type": "integer", "minimum": 0 },
        "stacks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 7,
          "items": {
            "type": "object",
            "required": ["unitId", "count"],
            "properties": {
              "unitId": { "type": "string", "minLength": 1 },
              "count":  { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "setFlag": {
      "type": "object",
      "description": "Set or clear a scenario flag. Used by map triggers and quest scripts.",
      "required": ["kind", "flagId", "value"],
      "properties": {
        "kind":   { "const": "set_flag" },
        "flagId": { "type": "string", "minLength": 1 },
        "value":  { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "awardResources": {
      "type": "object",
      "description": "One-time payout of multiple resources. Used by map triggers and quest rewards.",
      "required": ["kind", "amounts"],
      "properties": {
        "kind":     { "const": "award_resources" },
        "playerId": { "type": "integer", "minimum": 0 },
        "amounts": {
          "type": "object",
          "propertyNames": { "$ref": "heroes-reforged/resource-id.schema.json" },
          "additionalProperties": { "type": "integer" },
          "minProperties": 1
        }
      },
      "additionalProperties": false
    },
    "growthModifier": {
      "type": "object",
      "description": "Multiplicative growth modifier applied to a unit ID (or `*` for all units) for the active week. Used by themed-week records and similar weekly content.",
      "required": ["kind", "unitId", "multiplierNum", "multiplierDen"],
      "properties": {
        "kind":          { "const": "growth_modifier" },
        "unitId":        { "type": "string", "minLength": 1, "description": "Stable unit ID, or `*` for any unit." },
        "multiplierNum": { "type": "integer" },
        "multiplierDen": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  }
}
