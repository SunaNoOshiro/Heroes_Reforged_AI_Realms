{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heroes-reforged/provider-failure.schema.json",
  "title": "Provider Failure",
  "description": "Closed taxonomy of provider transport-layer failures so the Generation UI can render distinct recovery actions instead of a generic 'failed' message. Independent of the shape/coherence/balance retry classes — both can fire on the same generation. Four classes: `transport` (auto-retry with backoff), `auth` (re-auth flow, no retry), `quota` (cool-down timer in UI), `content-policy` (re-prompt UX, no auto-retry).",
  "type": "object",
  "required": ["kind"],
  "oneOf": [
    {
      "type": "object",
      "required": ["kind", "providerId", "message"],
      "properties": {
        "kind":       { "const": "transport" },
        "providerId": { "type": "string", "minLength": 1 },
        "message":    { "type": "string", "minLength": 1 },
        "httpStatus": { "type": "integer" },
        "retryAfterMs": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["kind", "providerId", "message"],
      "properties": {
        "kind":       { "const": "auth" },
        "providerId": { "type": "string", "minLength": 1 },
        "message":    { "type": "string", "minLength": 1 },
        "reauthUrl":  { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["kind", "providerId", "message"],
      "properties": {
        "kind":       { "const": "quota" },
        "providerId": { "type": "string", "minLength": 1 },
        "message":    { "type": "string", "minLength": 1 },
        "cooldownMs": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["kind", "providerId", "message"],
      "properties": {
        "kind":       { "const": "content-policy" },
        "providerId": { "type": "string", "minLength": 1 },
        "message":    { "type": "string", "minLength": 1 },
        "policyCode": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  ]
}
