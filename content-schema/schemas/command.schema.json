          "const": "RECRUIT_UNITS"
        },
        "heroId": {
          "type": "string",
          "minLength": 1
        },
        "townId": {
          "type": "string",
          "minLength": 1
        },
        "dwellingUnitId": {
          "type": "string",
          "minLength": 1
        },
        "quantity": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "buildBuilding": {
      "type": "object",
      "required": [
        "kind",
        "townId",
        "buildingId"
      ],
      "properties": {
        "kind": {
          "const": "BUILD_BUILDING"
        },
        "townId": {
          "type": "string",
          "minLength": 1
        },
        "buildingId": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "learnSpell": {
      "type": "object",
      "required": [
        "kind",
