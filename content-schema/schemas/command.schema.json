  "$defs": {
    "moveHero": {
      "type": "object",
      "required": [
        "kind",
        "heroId",
        "path"
      ],
      "properties": {
        "kind": {
          "const": "MOVE_HERO"
        },
        "heroId": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "q",
              "r"
            ],
            "properties": {
              "q": {
                "type": "integer"
              },
              "r": {
                "type": "integer"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "endHeroTurn": {
      "type": "object",
      "required": [
        "kind",
        "heroId"
      ],
      "properties": {
        "kind": {
          "const": "END_HERO_TURN"
        },
        "heroId": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "endDay": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "const": "END_DAY"
        }
      },
      "additionalProperties": false
    },
    "recruitUnits": {
      "type": "object",
      "required": [
        "kind",
        "heroId",
        "townId",
        "dwellingUnitId",
        "quantity"
