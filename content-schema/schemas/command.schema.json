        "townId",
        "spellId"
      ],
      "properties": {
        "kind": {
          "const": "LEARN_SPELL"
        },
        "heroId": {
          "type": "string",
          "minLength": 1
        },
        "townId": {
          "type": "string",
          "minLength": 1
        },
        "spellId": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "captureMine": {
