          "type": "string",
          "minLength": 1
        },
        "playerId": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "initiateBattle": {
      "type": "object",
      "required": [
        "kind",
        "attackerId",
        "defenderId",
        "autoResolve"
      ],
      "properties": {
        "kind": {
          "const": "INITIATE_BATTLE"
        },
        "attackerId": {
          "type": "string",
          "minLength": 1
        },
        "defenderId": {
          "type": "string",
          "minLength": 1
        },
        "autoResolve": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "battleAttack": {
      "type": "object",
      "required": [
        "kind",
        "attackerStackId",
        "defenderStackId",
        "targetPosition"
      ],
      "properties": {
        "kind": {
          "const": "BATTLE_ATTACK"
        },
        "attackerStackId": {
          "type": "string",
          "minLength": 1
        },
        "defenderStackId": {
          "type": "string",
          "minLength": 1
        },
        "targetPosition": {
          "type": "object",
          "required": [
            "q",
            "r"
          ],
          "properties": {
            "q": {
              "type": "integer"
            },
            "r": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "battleWait": {
      "type": "object",
      "required": [
        "kind",
        "stackId"
      ],
      "properties": {
        "kind": {
          "const": "BATTLE_WAIT"
        },
        "stackId": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "battleDefend": {
      "type": "object",
      "required": [
        "kind",
        "stackId"
      ],
      "properties": {
        "kind": {
          "const": "BATTLE_DEFEND"
        },
        "stackId": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "autoResolveBattle": {
      "type": "object",
      "required": [
        "kind",
        "attackerArmyId",
        "defenderArmyId"
      ],
      "properties": {
        "kind": {
          "const": "AUTO_RESOLVE_BATTLE"
        },
        "attackerArmyId": {
          "type": "string",
          "minLength": 1
        },
        "defenderArmyId": {
          "type": "string",
          "minLength": 1
        },
        "attackerHeroId": {
          "type": [
            "string",
            "null"
          ]
        },
        "defenderHeroId": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
