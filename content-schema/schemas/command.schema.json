    "battleResolved": {
      "type": "object",
      "required": [
        "kind",
        "winnerId"
      ],
      "properties": {
        "kind": {
          "const": "BATTLE_RESOLVED"
        },
        "winnerId": {
          "type": [
            "string",
            "null"
          ]
        },
        "winnerArmy": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "unitId",
              "count",
              "hp"
            ],
            "properties": {
              "unitId": {
                "type": "string",
                "minLength": 1
              },
              "count": {
                "type": "integer",
                "minimum": 0
              },
              "hp": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        },
        "loserArmy": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "unitId",
              "count",
              "hp"
            ],
            "properties": {
              "unitId": {
                "type": "string",
                "minLength": 1
              },
              "count": {
                "type": "integer",
                "minimum": 0
              },
              "hp": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "scenarioLoad": {
      "type": "object",
      "required": [
        "kind",
        "scenarioId",
        "seed"
      ],
      "properties": {
        "kind": {
          "const": "SCENARIO_LOAD"
        },
        "scenarioId": {
          "type": "string",
          "minLength": 1
        },
        "seed": {
          "type": "integer"
        },
        "contentHashes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "stringId": {
      "type": "string",
      "minLength": 1
    },
    "hexCoord": {
      "type": "object",
      "required": [
        "q",
        "r"
      ],
      "properties": {
        "q": {
          "type": "integer"
        },
        "r": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "resourceBundle": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "gold",
          "wood",
          "ore",
          "mercury",
          "sulfur",
          "crystal",
          "gems"
        ]
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "primaryStats": {
      "type": "object",
      "required": [
        "attack",
        "defense",
        "power",
        "knowledge"
      ],
      "properties": {
        "attack": {
          "type": "integer"
        },
        "defense": {
          "type": "integer"
        },
        "power": {
          "type": "integer"
        },
        "knowledge": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "battleMove": {
      "type": "object",
      "required": [
        "kind",
        "stackId",
        "path"
      ],
      "properties": {
        "kind": {
          "const": "BATTLE_MOVE"
        },
        "stackId": {
          "$ref": "#/$defs/stringId"
        },
        "path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/hexCoord"
          }
        }
      },
      "additionalProperties": false
    },
    "spellCast": {
      "type": "object",
      "required": [
        "kind",
        "casterId",
        "spellId",
        "target"
      ],
      "properties": {
        "kind": {
          "const": "SPELL_CAST"
        },
        "casterId": {
          "$ref": "#/$defs/stringId"
        },
        "spellId": {
          "$ref": "#/$defs/stringId"
        },
        "target": {
          "type": "object",
          "properties": {
            "stackId": {
              "type": [
                "string",
                "null"
              ]
            },
            "position": {
              "anyOf": [
                {
                  "$ref": "#/$defs/hexCoord"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "levelUp": {
      "type": "object",
      "required": [
        "kind",
        "heroId",
        "newLevel",
        "newPrimaryStats"
      ],
      "properties": {
        "kind": {
          "const": "LEVEL_UP"
        },
        "heroId": {
          "$ref": "#/$defs/stringId"
        },
        "newLevel": {
          "type": "integer",
          "minimum": 2
        },
        "newPrimaryStats": {
          "$ref": "#/$defs/primaryStats"
        }
      },
