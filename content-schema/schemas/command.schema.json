          "$ref": "#/$defs/stringId"
        },
        "skillId": {
          "$ref": "#/$defs/stringId"
        },
        "skillLevel": {
          "enum": [
            "basic",
            "advanced",
            "expert"
          ]
        }
      },
      "additionalProperties": false
    },
    "tradeResources": {
      "type": "object",
      "required": [
        "kind",
        "playerId",
        "fromResource",
        "toResource",
        "amount"
      ],
      "properties": {
        "kind": {
          "const": "TRADE_RESOURCES"
        },
        "playerId": {
          "type": "integer",
          "minimum": 0
        },
        "marketplaceId": {
          "type": [
            "string",
            "null"
          ]
        },
        "fromResource": {
          "enum": [
            "gold",
            "wood",
            "ore",
            "mercury",
            "sulfur",
            "crystal",
            "gems"
          ]
        },
        "toResource": {
          "enum": [
            "gold",
            "wood",
            "ore",
            "mercury",
            "sulfur",
            "crystal",
            "gems"
          ]
        },
        "amount": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "hireTavernHero": {
      "type": "object",
      "required": [
        "kind",
        "playerId",
