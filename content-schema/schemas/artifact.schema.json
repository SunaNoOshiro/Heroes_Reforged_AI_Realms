{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heroes-reforged/artifact.schema.json",
  "title": "Artifact",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "rarity",
    "slotIds",
    "effects"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "id":            { "type": "string", "minLength": 1 },
    "name":          { "type": "string", "minLength": 1 },
    "rarity":        { "type": "string", "enum": ["treasure", "minor", "major", "relic"] },
    "slotIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "heroes-reforged/effect.schema.json" }
    },
    "combo": {
      "type": "object",
      "required": ["setId", "requires"],
      "properties": {
        "setId":    { "type": "string", "minLength": 1 },
        "requires": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "effects": {
          "type": "array",
          "items": { "$ref": "heroes-reforged/effect.schema.json" }
        }
      },
      "additionalProperties": false
    },
    "restrictions": {
      "type": "object",
      "properties": {
        "requiredFactionIds":    { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "forbiddenFactionIds":   { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "requiredHeroClassIds":  { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "forbiddenHeroClassIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": false
    },
    "presentation": {
      "type": "object",
      "properties": {
        "iconId":             { "type": "string" },
        "inventoryCardArtId": { "type": "string" },
        "paperDollLayerId":   { "type": "string" },
        "vfxSetId":           { "type": "string" },
        "soundSetId":         { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
