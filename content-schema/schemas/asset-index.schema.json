{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heroes-reforged/asset-index.schema.json",
  "title": "Asset Index",
  "type": "object",
  "required": [
    "schemaVersion",
    "packId",
    "assets"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "packId": { "type": "string" },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "path",
          "sha256"
        ],
        "properties": {
          "id":   { "type": "string" },
          "kind": { "type": "string" },
          "path": { "type": "string" },
          "sha256": {
            "type": "string",
            "description": "Hex SHA-256 of the asset bytes. Recomputed by `npm run build:asset-index`. Mismatch at load time is fatal: pack.error.asset.integrity.",
            "pattern": "^[a-f0-9]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0,
            "description": "Optional file size hint so the loader can pre-flight quota before downloading."
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
