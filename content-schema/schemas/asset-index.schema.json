{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heroes-reforged/asset-index.schema.json",
  "title": "Asset Index",
  "type": "object",
  "required": [
    "schemaVersion",
    "packId",
    "assets"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "packId": { "type": "string" },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "path"
        ],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
