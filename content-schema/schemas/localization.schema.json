{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heroes-reforged/localization.schema.json",
  "title": "Localization Bundle",
  "description": "Locale-scoped UI string table. Gameplay records store stable IDs; localized labels, disabled reasons, status text, and errors live here.",
  "type": "object",
  "required": [
    "schemaVersion",
    "locale",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "locale": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$"
    },
    "fallbackLocale": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$"
    },
    "entries": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z0-9]+([.-][a-z0-9*]+)*$"
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": [
              "text"
            ],
            "properties": {
              "text": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string"
              },
              "placeholders": {
                "type": "object",
                "additionalProperties": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "interpolation": {
                "type": "object",
                "description": "Per-key interpolation contract per `ugc-safety.md` § ICU Locks. Default `mode = literal` escapes `{` / `}`. UGC-supplied translation files MAY NOT raise the interpolation tier of an existing canonical key.",
                "additionalProperties": false,
                "properties": {
                  "mode": {
                    "enum": ["literal", "named", "icu"],
                    "default": "literal"
                  },
                  "allowedTokens": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^[a-zA-Z][a-zA-Z0-9_]{0,31}$"
                    },
                    "uniqueItems": true,
                    "default": []
                  }
                }
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
